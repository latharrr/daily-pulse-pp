# Secret used to sign session JWTs. Required in production -- the app will
# refuse to boot without it (NODE_ENV=production). Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=

# Web app URL of the deployed Google Apps Script backend (see
# google-apps-script/Code.gs for setup instructions). When unset, the app
# falls back to an in-memory mock data store -- fine for local development,
# but data is lost on every restart and it must never be used in production.
GOOGLE_SCRIPT_URL=

# API token required by the Google Apps Script backend. Must match the
# API_TOKEN script property set in the Apps Script project.
GOOGLE_SCRIPT_TOKEN=
